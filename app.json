{
  "expo": {
    "name": "Neighborly",
    "slug": "neighborly",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.neighborly",
      "icon": "./assets/icon.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FBF6EC",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "READ_CALENDAR",
        "WRITE_CALENDAR"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-splash-screen",
      [
        "expo-calendar",
        {
          "calendarPermission": "Neighborly uses your calendar to add events you RSVP to."
        }
      ],
      "@maplibre/maplibre-react-native",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "baseUrl": "/neighborly"
    }
  }
}
