# Copy this file to .env and fill in real values. Never commit .env.
#
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY: Project Settings -> API in the
# Supabase dashboard. The service role key bypasses every RLS policy in the
# app — treat it like a root database password. This file must never be
# committed, shared, or deployed anywhere public.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Login for this dashboard itself (shown at http://localhost:4287).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Any long random string — used to sign the login session cookie.
SESSION_SECRET=change-me-too

# Optional — defaults to 4287 if unset.
PORT=4287
